{
  "name": "gs-qa-e2e-testing",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + Cucumber BDD framework for API and UI automation",
  "scripts": {
    "cucumber:run": "node scripts/run-cucumber-with-report.js",
    "test:api": "npm run cucumber:run -- --tags @api",
    "test:address": "npm run cucumber:run -- --tags @address",
    "test:latest": "npm run cucumber:run -- --tags @latest",
    "test:ui": "npm run cucumber:run -- --tags @ui",
    "test:smoke": "npm run cucumber:run -- --tags @smoke",
    "test:regression": "npm run cucumber:run -- --tags @regression",
    "report:html": "node scripts/generate-html-report.js"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "cucumber-html-reporter": "^5.5.0"
  }
}
